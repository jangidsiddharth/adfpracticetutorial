{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "azurepracticals"
		},
		"CopyDataBlobToBlob_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'CopyDataBlobToBlob'"
		},
		"filtersortdataflow_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'filtersortdataflow'"
		},
		"jointransformation_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'jointransformation'"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "azurepracticals_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"CopyDataBlobToBlob_connectionString": {
						"value": "[parameters('CopyDataBlobToBlob_connectionString')]"
					},
					"filtersortdataflow_connectionString": {
						"value": "[parameters('filtersortdataflow_connectionString')]"
					},
					"jointransformation_connectionString": {
						"value": "[parameters('jointransformation_connectionString')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}